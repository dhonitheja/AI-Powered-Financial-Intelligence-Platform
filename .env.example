# Wealthix Environment Variables
# Copy to .env and fill in values. NEVER commit .env to git.

# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://host:5432/wealthix
DATABASE_USERNAME=
DATABASE_PASSWORD=

# JWT (generate with: openssl rand -base64 64)
JWT_SECRET=
JWT_EXPIRATION_MS=86400000

# Encryption (generate with: openssl rand -base64 32)
ENCRYPTION_KEY=

# Plaid
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# Stripe
STRIPE_SECRET_KEY=sk_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_...

# AI Service
GOOGLE_API_KEY=
INTERNAL_AI_SERVICE_SECRET=
AI_SERVICE_URL=http://wealthix-ai:8000

# Frontend
NEXT_PUBLIC_API_URL=https://api.wealthix.app
